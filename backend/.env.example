# ============================================================
# Backend .env — api.insurance.careerxera.com
# Place this file at: public_html/api.insurance.careerxera.com/.env
# (or wherever your backend root is on Hostinger)
# ============================================================

APP_ENV=production
APP_URL=https://api.insurance.careerxera.com

# ── MySQL (from cPanel → MySQL Databases) ────────────────────
# cPanel format: cpanelusername_dbname / cpanelusername_dbuser
DB_HOST=localhost
DB_NAME=CPANEL_USERNAME_tiles
DB_USER=CPANEL_USERNAME_tiles
DB_PASS=YOUR_DB_PASSWORD_HERE

# ── JWT — generate with: openssl rand -hex 64 ────────────────
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING

# ── Frontend origin (for CORS) ────────────────────────────────
FRONTEND_URL=https://insurance.careerxera.com
